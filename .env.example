# Copy to .env and adjust. Consumed by docker-compose.

# --- Kafka ---
KAFKA_BROKER=kafka:9092
KAFKA_TOPIC_SCORES=trustlens.scores
KAFKA_TOPIC_INGEST=trustlens.ingest

# --- ClickHouse ---
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=trustlens
CLICKHOUSE_USER=trustlens
CLICKHOUSE_PASSWORD=trustlens

# --- Superset ---
SUPERSET_SECRET_KEY=change-me-in-prod
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASSWORD=admin

# --- Airflow ---
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
# Operating point the classifier is thresholded at.
TARGET_FPR=0.01

# --- Kaggle (for scripts/download_140k_faces.sh) ---
# Put kaggle.json in ~/.kaggle/ or set these:
KAGGLE_USERNAME=
KAGGLE_KEY=
